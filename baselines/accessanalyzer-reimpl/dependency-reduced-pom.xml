<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <parent>
    <artifactId>accessrefinery</artifactId>
    <groupId>org.ants</groupId>
    <version>1.0</version>
    <relativePath>../../pom.xml</relativePath>
  </parent>
  <modelVersion>4.0.0</modelVersion>
  <artifactId>accessanalyzer</artifactId>
  <build>
    <plugins>
      <plugin>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.5.0</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <transformers>
                <transformer>
                  <mainClass>org.aws.Main</mainClass>
                </transformer>
              </transformers>
              <outputDirectory>${project.parent.build.directory}</outputDirectory>
              <finalName>accessanalyzer-1.0</finalName>
            </configuration>
          </execution>
        </executions>
        <configuration>
          <shadeSystemScope>true</shadeSystemScope>
          <createDependencyReducedPom>true</createDependencyReducedPom>
          <filters>
            <filter>
              <artifact>*:*</artifact>
              <excludes>
                <exclude>META-INF/*.SF</exclude>
                <exclude>META-INF/*.DSA</exclude>
                <exclude>META-INF/*.RSA</exclude>
              </excludes>
            </filter>
          </filters>
        </configuration>
      </plugin>
    </plugins>
  </build>
  <profiles>
    <profile>
      <id>linux-x86_64</id>
      <properties>
        <z3.classifier>x64-glibc-2.35</z3.classifier>
        <cvc5.classifier>linux-x86_64</cvc5.classifier>
      </properties>
    </profile>
  </profiles>
  <dependencies>
    <dependency>
      <groupId>io.github.cvc5</groupId>
      <artifactId>cvc5</artifactId>
      <version>1.2.1</version>
      <classifier>linux-x86_64</classifier>
      <scope>system</scope>
      <systemPath>/home/nkang/Desktop/accessrefinery/baselines/accessanalyzer-reimpl/lib/cvc5-1.2.1/cvc5-1.2.1-linux-x86_64.jar</systemPath>
    </dependency>
    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter</artifactId>
      <version>5.9.3</version>
      <scope>test</scope>
      <exclusions>
        <exclusion>
          <artifactId>junit-jupiter-api</artifactId>
          <groupId>org.junit.jupiter</groupId>
        </exclusion>
        <exclusion>
          <artifactId>junit-jupiter-params</artifactId>
          <groupId>org.junit.jupiter</groupId>
        </exclusion>
        <exclusion>
          <artifactId>junit-jupiter-engine</artifactId>
          <groupId>org.junit.jupiter</groupId>
        </exclusion>
      </exclusions>
    </dependency>
    <dependency>
      <groupId>io.github.cvc5</groupId>
      <artifactId>cvc5</artifactId>
      <version>1.2.1</version>
      <classifier>${cvc5.classifier}</classifier>
      <scope>system</scope>
      <systemPath>${project.basedir}/lib/cvc5-1.2.1/cvc5-1.2.1-${cvc5.classifier}.jar</systemPath>
    </dependency>
    <dependency>
      <groupId>com.microsoft</groupId>
      <artifactId>z3</artifactId>
      <version>4.14.1</version>
      <scope>system</scope>
      <systemPath>${project.basedir}/lib/z3-4.14.1/bin/com.microsoft.z3.jar</systemPath>
    </dependency>
  </dependencies>
  <properties>
    <maven.compiler.target>17</maven.compiler.target>
    <maven.compiler.source>17</maven.compiler.source>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <maven.javadoc.skip>true</maven.javadoc.skip>
  </properties>
</project>
