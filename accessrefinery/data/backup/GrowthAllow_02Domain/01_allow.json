{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Effect": "Allow",
            "Principal": {
                "AWS": "*"
            },
            "Action": "s3:ListBucket",
            "Resource": "arn:aws:s3:::antsknmath",
            "Condition": {
                "StringLike": {
                    "aws:PrincipalArn": "arn:aws:iam::123456789012:user/*bcdefghijklmnopqrst",
                    "aws:PrincipalId": "*bcdefghijklmnopqrst"
                }
            }
        }
    ]
}
