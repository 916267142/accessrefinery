{
    "Version": "5.0",
    "Statement": [
        {
            "Effect": "Allow",
            "Principal": {
                "IAM": [
                    "*"
                ]
            },
            "Action": [
                "sts:agencies:assume"
            ],
            "Condition": {
                "StringMatchIfExists": {
                    "g:UserId": [
                        "a*b*a*b*"
                    ]
                },
                "StringNotMatch": {
                    "g:PrincipalId": [
                        "a*ba*b*",
                        "a*b?a*b*",
                        "a*b??a*b*",
                        "a*b???a*b*",
                        "a*b????a*b*",
                        "a*b?????a*b*",
                        "a*b??????*a*b*"
                    ]
                },
                "StringEquals": {
                    "g:PrincipalType": [
                        "User"
                    ]
                }
            }
        }
    ]
}