{
    "Version": "5.0",
    "Statement": [
        {
            "Effect": "Allow",
            "Principal": {
                "IAM": [
                    "*"
                ]
            },
            "Action": [
                "sts:agencies:assume"
            ],
            "Condition": {
                "StringMatch": {
                    "g:CalledViaFirst": [
                        "service.a*b*c*d*e*f*g*"
                    ],
                    "g:CalledViaLast": [
                        "service.*a*b*c*d*e*f*g"
                    ]
                },
                "ForAllValues:StringNotMatch": {
                    "g:CalledVia": [
                        "service.*a*?b*c*d*e*f*g*",
                        "service.*a*b*?c*d*e*f*g*",
                        "service.*a*b*c*?d*e*f*g*",
                        "service.*a*b*c*d*?e*f*g*",
                        "service.*a*b*c*d*e*?f*g*",
                        "service.*a*b*c*d*e*f*?g*"
                    ]
                },
                "ForAnyValue:StringMatch": {
                    "g:CalledVia": [
                        "service.*?a*b*c*d*e*f*g?*"
                    ]
                }
            }
        }
    ]
}