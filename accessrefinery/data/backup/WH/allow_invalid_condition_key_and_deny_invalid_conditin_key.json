{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Effect": "Allow",
            "Principal": {
                "IAM": "123456789012" 
            },
            "Action": [
                "sts:agencies:assume"
            ],
            "Condition": {
                "StringMatch": {
                    "g:noexist": "123"
                }
            }
        },
        {
            "Effect": "Allow",
            "Principal": {
                "IAM": "123456789012" 
            },
            "Action": [
                "sts::setSourceIdentity"
            ],
            "Condition": {
                "StringMatch": {
                    "g:PrincipalUrn": "*user*"
                }
            }
        },
        {
            "Effect": "Deny",
            "Principal": {
                "IAM": "*" 
            },
            "Action" : [
                "*"
            ],
            "Condition": {
                "StringNotMatch": {
                    "g:anothernoexist": "456"
                }
            }
        }
    ]
}
