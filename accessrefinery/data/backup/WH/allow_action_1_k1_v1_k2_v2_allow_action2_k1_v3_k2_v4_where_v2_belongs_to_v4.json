{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Effect": "Allow",
            "Principal": {
                "IAM": "user1" 
            },
            "Action": [
                "sts:agencies:assume"
            ],
            "Condition": {
                "IPAddress": {
                    "g:SourceIp": "10.10.10.10"
                },
                "StringMatch": {
                    "g:PrincipalUrn": "*a*bA"
                }
            }
        },
        {
            "Effect": "Allow",
            "Principal": {
                "IAM": "user1" 
            },
            "Action" : [
                "sts::setSourceIdentity"
            ],
            "Condition": {
                "IPAddress": {
                    "g:SourceIp": "10.10.10.11"
                },
                "StringMatch": {
                    "g:PrincipalUrn": "*a*b*"
                }
            }
        }
    ]
}
