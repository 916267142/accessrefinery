{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Effect": "Allow",
            "Principal": {
                "IAM": "*" 
            },
            "Action": [
                "sts:agencies:assume",
                "sts::setSourceIdentity"
            ],
            "Condition": {
                "StringEquals": {
                    "g:PrincipalAccount": "2333"
                }
            }
        },
        {
            "Effect": "Deny",
            "Principal": {
                "IAM": "*" 
            },
            "Action": [
                "sts:agencies:assume"
            ],
            "Condition": {
                "StringMatch": {
                    "g:PrincipalUrn": "*:*:2333:*:*"
                }
            }
        }
      ]
}
