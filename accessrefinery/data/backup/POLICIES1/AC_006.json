{
    "Version": "5.0",
    "Statement": [
        {
            "Effect": "Allow",
            "Principal": {
                "IAM": [
                    "*"
                ]
            },
            "Action": [
                "sts:agencies:assume"
            ],
            "Condition": {
                "StringEquals": {
                    "g:PrincipalUrn": [
                        "iam::abcdefghijklmnopqrstuvwxyz:user:abcdefghijklmnopqrstuvwxyz"
                    ]
                }
            }
        },
        {
            "Effect": "Deny",
            "Principal": {
                "IAM": [
                    "*"
                ]
            },
            "Action": [
                "sts:agencies:assume"
            ],
            "Condition": {
                "StringMatch": {
                    "g:PrincipalAccount": [
                        "*a*",
                        "*B*",
                        "*c*",
                        "*D*",
                        "*e*",
                        "*f*",
                        "*G*",
                        "*h*",
                        "*i*"
                    ]
                }
            }
        },
        {
            "Effect": "Deny",
            "Principal": {
                "IAM": [
                    "*"
                ]
            },
            "Action": [
                "sts:agencies:assume"
            ],
            "Condition": {
                "StringMatch": {
                    "g:UserName": [
                        "*a*",
                        "*B*",
                        "*c*",
                        "*D*",
                        "*e*",
                        "*f*",
                        "*G*",
                        "*h*",
                        "*i*"
                    ]
                }
            }
        }
    ]
}