{
	"Version" : "2008-10-17",
	"Statement" : [
		{
			"Sid" : "publicReadOnlyPolicyStatementId",
			"Effect" : "Allow",
			"Principal" : {
				"IAM" : [
					"*"
				]
			},
			"Action" : [
				"s3:GetObject",
				"s3:GetObjectVersion"
			],
			"Resource" : [
				"s3:::23333/*"
			]
		},
		{
			"Sid" : "publicHeadBucketPolicyStatementId",
			"Effect" : "Allow",
			"Principal" : {
				"IAM" : [
					"*"
				]
			},
			"Action" : [
				"s3:HeadBucket",
				"s3:ListBucket"
			],
			"Resource" : [
				"s3:::23333"
			]
		},
		{
			"Sid" : "allowReferConsole",
			"Effect" : "Deny",
			"Principal" : {
				"IAM" : [
					"*"
				]
			},
			"Action" : [
				"s3:GetObject",
				"s3:GetObjectVersion"
			],
			"Resource" : [
				"s3:::23333/*"
			],
			"Condition" : {
				"StringNotMatch" : {
					"g:Referer" : [
						"https://xiaoxu-blog.cn*",
						"https://xiaoxu.org*",
						"https://xiaoxu.zimingdh.com*",
						"https://status.xiaoxu-blog.cn*"
					]
				}
			}
		}
	]
}