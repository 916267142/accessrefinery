{
	"Version" : "2008-10-17",
	"Id" : "Policy1615800649734",
	"Statement" : [
		{
			"Sid" : "公共读-测试公共读取",
			"Effect" : "Allow",
			"Principal" : {
				"IAM" : [
					"*"
				]
			},
			"Action" : [
				"s3:ListBucket",
				"s3:HeadBucket",
				"s3:GetBucketLocation",
				"s3:ListBucketVersions",
				"s3:GetObject",
				"s3:GetObjectVersion"
			],
			"Resource" : [
				"s3:::ai-meida-file",
				"s3:::ai-meida-file/*"
			]
		}
	]
}