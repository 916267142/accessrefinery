{
	"Version" : "2008-10-17",
	"Id" : "Policy1626591829102",
	"Statement" : [
		{
			"Sid" : "公共读写-d289",
			"Effect" : "Allow",
			"Principal" : {
				"IAM" : [
					"*"
				]
			},
			"Action" : [
				"s3:ListBucket",
				"s3:HeadBucket",
				"s3:GetBucketLocation",
				"s3:ListBucketVersions",
				"s3:ListBucketMultipartUploads",
				"s3:GetObject",
				"s3:PutObject",
				"s3:RestoreObject",
				"s3:GetObjectAcl",
				"s3:PutObjectAcl",
				"s3:GetObjectVersion",
				"s3:GetObjectVersionAcl",
				"s3:AbortMultipartUpload",
				"s3:ListMultipartUploadParts",
				"s3:ModifyObjectMetaData"
			],
			"Resource" : [
				"s3:::bojoe-admin",
				"s3:::bojoe-admin/*"
			]
		}
	]
}